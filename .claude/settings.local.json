{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash",
      "WebSearch",
      "Bash(python3 -)",
      "Bash(cargo check *)",
      "Bash(cargo test *)",
      "Bash(cargo build *)",
      "Bash(cargo doc *)",
      "Bash(awk -F'[.;]' '{p+=$2; f+=$3} END {print \"total passed:\" p, \"failed:\" f}')",
      "Bash(ls reports/server.json)",
      "Bash(pgrep -f \"hellfire server\")",
      "Bash(ls reports/)",
      "Bash(pkill -f \"hellfire server\")",
      "Bash(pkill -f \"hellfire bot\")",
      "Bash(cargo clippy *)",
      "Bash(echo \"clippy-exit: $?\")",
      "Bash(echo \"doc-exit: $?\")"
    ]
  }
}
